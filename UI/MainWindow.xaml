<Window x:Class="FontVault.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:FontVault.UI"
        Title="FontVault" Height="880" Width="1420" WindowStartupLocation="CenterScreen"
        Icon="/Assets/FontVault.ico">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <ui:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <ui:StringEmptyToVisibilityConverter x:Key="EmptyToVis" />
        <ui:StringNotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
        <ui:ExtensionToBrushConverter x:Key="ExtToBrush" />

        <Style x:Key="Icon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        </Style>
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="FlatList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Source / vault / errors toolbar -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <!-- Row A: source + actions + about -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Source" MinWidth="48" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                <Button Grid.Column="2" Margin="6,0,0,0" Padding="8,4" ToolTip="Pick the source folder"
                        Command="{Binding BrowseSourceCommand}">
                    <TextBlock Style="{StaticResource Icon}" Text="&#xE8B7;" Foreground="#F59E0B" />
                </Button>
                <CheckBox Grid.Column="3" Content="+ Windows fonts" IsChecked="{Binding IncludeWindowsFonts}"
                          VerticalAlignment="Center" Margin="10,0,0,0"
                          ToolTip="Also import C:\Windows\Fonts and the per-user fonts (%LocalAppData%\Microsoft\Windows\Fonts)." />
                <Button Grid.Column="4" Margin="10,0,0,0" Padding="12,4"
                        Style="{DynamicResource AccentButtonStyle}" Command="{Binding ScanCommand}"
                        ToolTip="Scan the sources, deduplicate, copy the best versions into the vault and rebuild the index.">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE768;" Margin="0,0,6,0" />
                        <TextBlock Text="Process" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="5" Margin="6,0,0,0" Padding="10,4"
                        Command="{Binding OpenLogsCommand}" ToolTip="Open the processing log (scan.log)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE8A5;" Foreground="#60A5FA" Margin="0,0,6,0" />
                        <TextBlock Text="Logs" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="6" Margin="6,0,0,0" Padding="10,4"
                        Command="{Binding CancelScanCommand}"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE711;" Foreground="#EF4444" Margin="0,0,6,0" />
                        <TextBlock Text="Cancel" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="7" Margin="6,0,0,0" Padding="11,4" Click="About_Click" ToolTip="About FontVault">
                    <TextBlock Text="?" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                </Button>
            </Grid>
            <!-- Row B: vault (left half) | errors (right half) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Vault" MinWidth="48" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Text="{Binding VaultPath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                <Button Grid.Column="2" Margin="6,0,0,0" Padding="8,4"
                        ToolTip="Pick the vault folder (font files only; the index lives next to the exe)"
                        Command="{Binding BrowseVaultCommand}">
                    <TextBlock Style="{StaticResource Icon}" Text="&#xE8B7;" Foreground="#F59E0B" />
                </Button>
                <TextBlock Grid.Column="4" Text="Errors" MinWidth="48" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="5" Text="{Binding ErrorPath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                <Button Grid.Column="6" Margin="6,0,0,0" Padding="8,4"
                        ToolTip="Pick the folder where fonts that fail to parse are copied"
                        Command="{Binding BrowseErrorCommand}">
                    <TextBlock Style="{StaticResource Icon}" Text="&#xE8B7;" Foreground="#F59E0B" />
                </Button>
            </Grid>
        </StackPanel>

        <!-- Sort / search / filters -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Sort" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Grid.Column="1" Width="120" ItemsSource="{Binding SortModes}"
                      SelectedItem="{Binding SelectedSortMode}" VerticalAlignment="Center" />
            <Grid Grid.Column="2" Margin="14,0,0,0">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="30,4,8,4" VerticalAlignment="Center" VerticalContentAlignment="Center" />
                <TextBlock Style="{StaticResource Icon}" Text="&#xE721;" Margin="10,0,0,0"
                           Foreground="Gray" IsHitTestVisible="False" HorizontalAlignment="Left" />
                <TextBlock Text="Search fonts…" Margin="32,0,0,0" Foreground="Gray"
                           VerticalAlignment="Center" IsHitTestVisible="False"
                           Visibility="{Binding SearchText, Converter={StaticResource EmptyToVis}}" />
            </Grid>
            <TextBlock Grid.Column="3" Text="Format" VerticalAlignment="Center" Margin="14,0,8,0" />
            <ComboBox Grid.Column="4" Width="96" ItemsSource="{Binding FormatFilters}"
                      SelectedItem="{Binding SelectedFormatFilter}" VerticalAlignment="Center" />
            <CheckBox Grid.Column="5" Content="Favorites" IsChecked="{Binding FavoritesOnly}"
                      VerticalAlignment="Center" Margin="14,0,0,0"
                      ToolTip="Only families marked as favorite (yellow star)." />
            <CheckBox Grid.Column="6" Content="Installed" IsChecked="{Binding InstalledOnly}"
                      VerticalAlignment="Center" Margin="14,0,0,0"
                      ToolTip="Only fonts currently installed in Windows (system or per-user)." />
            <CheckBox Grid.Column="7" Content="Variable" IsChecked="{Binding VariableOnly}"
                      VerticalAlignment="Center" Margin="14,0,0,0"
                      ToolTip="Only OpenType variable fonts (fvar axes)." />
        </Grid>

        <!-- Body: families | variants | tabs -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="4,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE8D2;" Foreground="#818CF8" />
                        <TextBlock Grid.Column="1" Style="{StaticResource CardHeader}" Text="Families" />
                        <ToggleButton Grid.Column="3" x:Name="FamiliesHelpToggle" Padding="6,2"
                                      ToolTip="Icons legend">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE897;" FontSize="12" />
                        </ToggleButton>
                        <Popup PlacementTarget="{Binding ElementName=FamiliesHelpToggle}" Placement="Bottom"
                               StaysOpen="False" AllowsTransparency="True"
                               IsOpen="{Binding IsChecked, ElementName=FamiliesHelpToggle, Mode=TwoWay}">
                            <Border CornerRadius="8" BorderThickness="1" Padding="14" Margin="0,4,8,8"
                                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                                <StackPanel Width="290">
                                    <TextBlock Text="Legend" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#0284C7">
                                            <TextBlock Text="A" Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="Family initial — the chip color is derived from the letter."
                                                   Margin="10,0,0,0" TextWrapping="Wrap" Width="240" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border CornerRadius="8" Background="#33808080" Padding="7,1" VerticalAlignment="Center">
                                            <TextBlock Text="12" FontSize="11" />
                                        </Border>
                                        <TextBlock Text="Number of variants (styles) in the family."
                                                   Margin="10,0,0,0" TextWrapping="Wrap" Width="226" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Variant badge — container format:" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="4" Padding="6,1" Background="#0E7490">
                                            <TextBlock Text=".otf" FontSize="10" Foreground="White" />
                                        </Border>
                                        <Border CornerRadius="4" Padding="6,1" Background="#15803D" Margin="6,0,0,0">
                                            <TextBlock Text=".ttf" FontSize="10" Foreground="White" />
                                        </Border>
                                        <Border CornerRadius="4" Padding="6,1" Background="#7C3AED" Margin="6,0,0,0">
                                            <TextBlock Text=".woff" FontSize="10" Foreground="White" />
                                        </Border>
                                        <Border CornerRadius="4" Padding="6,1" Background="#9333EA" Margin="6,0,0,0">
                                            <TextBlock Text=".woff2" FontSize="10" Foreground="White" />
                                        </Border>
                                        <Border CornerRadius="4" Padding="6,1" Background="#6B7280" Margin="6,0,0,0">
                                            <TextBlock Text=".eot" FontSize="10" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <ListBox Grid.Row="1" x:Name="FamiliesList" Style="{StaticResource FlatList}"
                             ItemsSource="{Binding Families}" SelectedItem="{Binding SelectedFamily}"
                             ScrollViewer.IsDeferredScrollingEnabled="False"
                             PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="List_PreviewMouseMove">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="28" Height="28" CornerRadius="6" Background="{Binding ChipBrush}">
                                        <TextBlock Text="{Binding Letter}" Foreground="White" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0,6,0"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="2" CornerRadius="8" Background="#33808080"
                                            Padding="7,1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Count}" FontSize="11" />
                                    </Border>
                                    <Button Grid.Column="3" Margin="6,0,0,0" Padding="3,0" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Click="Favorite_Click" ToolTip="Toggle favorite">
                                        <TextBlock Text="&#xE735;" FontSize="14" VerticalAlignment="Center"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#666" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                            <Setter Property="Foreground" Value="#FACC15" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="4,0,0,8">
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE8E9;" Foreground="#34D399" />
                        <TextBlock Style="{StaticResource CardHeader}" Text="Variants" />
                    </StackPanel>
                    <ListBox Grid.Row="1" x:Name="VariantsList" Style="{StaticResource FlatList}"
                             ItemsSource="{Binding SelectedFamily.Entries}" SelectedItem="{Binding SelectedEntry}"
                             PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="List_PreviewMouseMove">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 ToolTip="Installed in Windows"
                                                 Visibility="{Binding IsInstalled, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding EffectiveStyle, Mode=OneWay}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,1" Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Background="{Binding Extension, Converter={StaticResource ExtToBrush}}">
                                        <TextBlock Text="{Binding ExtensionDisplay, Mode=OneWay}" FontSize="10"
                                                   Foreground="White" />
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Foreground="Gray" FontSize="11">
                                        <Run Text="v" /><Run Text="{Binding Version, Mode=OneWay}" />
                                        <Run Text=" · " /><Run Text="{Binding GlyphCount, Mode=OneWay}" /><Run Text=" glyphs" />
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Selected-font actions: always visible, independent of the active tab. -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,0,4,8">
                    <Button Padding="10,3" Command="{Binding ExportEntryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE74E;" Foreground="#60A5FA" Margin="0,0,6,0" />
                            <TextBlock Text="Export variant" />
                        </StackPanel>
                    </Button>
                    <Button Padding="10,3" Margin="8,0,0,0" Command="{Binding ExportFamilyCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE74E;" Foreground="#60A5FA" Margin="0,0,6,0" />
                            <TextBlock Text="Export family" />
                        </StackPanel>
                    </Button>
                    <ToggleButton Padding="10,3" Margin="16,0,0,0"
                                  IsChecked="{Binding IsSelectedInstalled}"
                                  IsEnabled="{Binding CanToggleInstall}"
                                  ToolTip="{Binding InstallToggleTooltip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE8FB;" Foreground="#22C55E" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding InstallToggleLabel}" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>

                <TabControl Grid.Row="1">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE946;" Foreground="#60A5FA" Margin="0,0,6,0" />
                            <TextBlock Text="Details" />
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Details}" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE7B3;" Foreground="#2DD4BF" Margin="0,0,6,0" />
                            <TextBlock Text="Preview" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="4,4,4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding PreviewText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" MaxHeight="60" VerticalScrollBarVisibility="Auto" />
                            <Slider Grid.Column="1" Width="140" Minimum="8" Maximum="160"
                                    Value="{Binding PreviewSize}" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <TextBlock Grid.Column="2" Text="{Binding PreviewSize, StringFormat={}{0:0} px}"
                                       VerticalAlignment="Center" Margin="4,0,0,0" Width="44" />
                        </Grid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,2,4,4">
                            <CheckBox Content="Show missing" IsChecked="{Binding ShowMissingChars}"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding ShapedMode, Converter={StaticResource InvBoolToVis}}"
                                      ToolTip="Checked: characters absent from the font are drawn as hollow boxes. Unchecked: included glyphs only." />
                            <CheckBox Content="Shaped (ligatures &amp; features)" IsChecked="{Binding ShapedMode}"
                                      VerticalAlignment="Center" Margin="12,0,0,0"
                                      ToolTip="System text stack rendering: ligatures and OpenType features active, with font fallback for absent characters." />
                            <StackPanel Orientation="Horizontal" Margin="12,0,0,0"
                                        Visibility="{Binding ShapedMode, Converter={StaticResource BoolToVis}}">
                                <CheckBox Content="liga" IsChecked="{Binding FeatLiga}" VerticalAlignment="Center" />
                                <CheckBox Content="dlig" IsChecked="{Binding FeatDlig}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <CheckBox Content="kern" IsChecked="{Binding FeatKern}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <CheckBox Content="smcp" IsChecked="{Binding FeatSmcp}" VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Row="2" CornerRadius="8" Background="White">
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Visibility="{Binding ShapedMode, Converter={StaticResource InvBoolToVis}}">
                                    <ui:FontPreviewControl FontPath="{Binding PreviewFontPath}"
                                                           Text="{Binding PreviewText}"
                                                           EmSize="{Binding PreviewSize}"
                                                           ShowMissing="{Binding ShowMissingChars}" />
                                </ScrollViewer>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Visibility="{Binding ShapedMode, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding PreviewText}"
                                               FontFamily="{Binding PreviewFontFamily}"
                                               FontSize="{Binding PreviewSize}"
                                               FontWeight="{Binding PreviewFontWeight}"
                                               FontStyle="{Binding PreviewFontStyle}"
                                               Typography.StandardLigatures="{Binding FeatLiga}"
                                               Typography.DiscretionaryLigatures="{Binding FeatDlig}"
                                               Typography.Kerning="{Binding FeatKern}"
                                               Typography.Capitals="{Binding CapitalsMode}"
                                               TextWrapping="Wrap" Margin="8" Foreground="Black" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE8C1;" Foreground="#F59E0B" Margin="0,0,6,0" />
                            <TextBlock Text="Glyphs" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" ItemsSource="{Binding GlyphBlocks}"
                                      SelectedItem="{Binding SelectedGlyphBlock}"
                                      VirtualizingPanel.IsVirtualizing="True">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <CheckBox Grid.Column="1" Content="Full block (show missing)"
                                      IsChecked="{Binding GlyphShowAll}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>
                        <Border Grid.Row="1" CornerRadius="8" Background="White">
                            <ListBox Style="{StaticResource FlatList}" ItemsSource="{Binding GlyphRows}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <ui:GlyphGridRowControl Row="{Binding}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE9E9;" Foreground="#A78BFA" Margin="0,0,6,0" />
                            <TextBlock Text="Variable axes" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Margin="6" Foreground="Gray"
                                   Text="Not a variable font — no axes to adjust."
                                   Visibility="{Binding HasVariableAxes, Converter={StaticResource InvBoolToVis}}" />
                        <Grid Grid.Row="0" Margin="4"
                              Visibility="{Binding HasVariableAxes, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ItemsControl Grid.Column="0" ItemsSource="{Binding AxisSliders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="180" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Tag}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <Slider Grid.Column="1" Minimum="{Binding Min}" Maximum="{Binding Max}"
                                                    Value="{Binding Value}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Value, StringFormat={}{0:0.##}}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                                            <TextBlock Grid.Column="3" Text="{Binding RangeText}" Foreground="Gray"
                                                       FontSize="11" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Grid.Column="1" Padding="10,3" Margin="6,2,0,0" VerticalAlignment="Top"
                                    Command="{Binding ResetAxesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE72C;" Foreground="#A78BFA" Margin="0,0,6,0" />
                                    <TextBlock Text="Reset" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Border Grid.Row="1" CornerRadius="8" Background="White">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ui:VariableFontPreviewControl FontPath="{Binding PreviewFontPath}"
                                                               Text="{Binding PreviewText}"
                                                               EmSize="{Binding PreviewSize}"
                                                               AxisValues="{Binding CurrentAxisValues}" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE71B;" Foreground="#F472B6" Margin="0,0,6,0" />
                            <TextBlock Text="Ligatures / GSUB" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="170" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource CardHeader}" Text="GSUB features" Margin="4,0,0,6" />
                                <ListBox Grid.Row="1" Style="{StaticResource FlatList}" ItemsSource="{Binding GsubFeatures}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Display}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="4,0,4,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource CardHeader}" Text="Ligatures (LookupType 4)" Margin="4,0,0,6" />
                                <ListBox Grid.Row="1" Style="{StaticResource FlatList}" ItemsSource="{Binding Ligatures}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="Padding" Value="2" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Components}" Width="220" VerticalAlignment="Center" />
                                                <TextBlock Text="→" VerticalAlignment="Center" Margin="4,0" />
                                                <Border Background="White" CornerRadius="4">
                                                    <ui:GlyphIndexControl FontPath="{Binding FontPath}"
                                                                          GlyphIndex="{Binding GlyphIndex}" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding CountText}" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
            <ProgressBar Grid.Column="2" Width="200" Height="14" Margin="8,0"
                         Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            <TextBlock Grid.Column="3" Text="{Binding ScanStatus}" VerticalAlignment="Center"
                       Visibility="{Binding ScanStatus, Converter={StaticResource NotEmptyToVis}}" />
        </Grid>
    </Grid>
</Window>
